{
  "$meta": {
    "name": "Le Mouvement — Deuxième Souffle Design Tokens",
    "version": "0.1.0",
    "source": "project/brief/Moodboard 1 App · Deuxième Souffle.pdf",
    "tiers": ["global (raw)", "semantic (alias)", "theme (coach | admin | ehpad)"],
    "principle": "Une base, trois intensités — same tokens, dosage changes per surface.",
    "colorScheme": "LOCKED 2026-06-08 — fixed per product, no user toggle in MVP: coach (mobile) = dark, ehpad (web) = light, admin/DS (web) = light. Rule: mobile = dark, web = light.",
    "accessibility": "Body >= 16px, touch targets >= 44px, contrast AA. Red text only on bold >= 16px."
  },

  "global": {
    "color": {
      "rouge": {
        "50": "#FDECEA", "100": "#FACFCB", "200": "#F4A8A1", "300": "#EE7B72",
        "400": "#E85248", "500": "#E1322B", "600": "#C32721", "700": "#9E1E19",
        "800": "#771613", "900": "#4F0E0C"
      },
      "or": {
        "50": "#FEF9E0", "100": "#FDEFB0", "200": "#FBE27A", "300": "#F8D544",
        "400": "#F5CB1F", "500": "#F2C200", "600": "#CCA300", "700": "#9E7E00",
        "800": "#6E5800", "900": "#463800"
      },
      "bleu": {
        "50": "#ECF0F8", "100": "#CDD8EC", "200": "#A6B7DB", "300": "#7B93C7",
        "400": "#4F6DAE", "500": "#2F4F92", "600": "#1F3B73", "700": "#182E5A",
        "800": "#122242", "900": "#0B152A"
      },
      "vert": {
        "50": "#E8F7EF", "100": "#C2EAD4", "200": "#93D9B5", "300": "#62C795",
        "400": "#41B47E", "500": "#2F9E6B", "600": "#268158", "700": "#1D6444",
        "800": "#154A32", "900": "#0D2F20"
      },
      "neutral": {
        "0": "#FFFFFF", "50": "#F7F4EF", "100": "#EDE8E0", "200": "#DED7CB",
        "300": "#C6BDAE", "400": "#A89E8D", "500": "#8A8377", "600": "#6B655B",
        "700": "#4D4842", "800": "#2E2B27", "900": "#181715"
      }
    },
    "gradient": {
      "movement": "linear-gradient(135deg, #E1322B 0%, #F2C200 100%)"
    }
  },

  "semantic": {
    "comment": "Shared alias layer — identical across all three surfaces. Never reference raw hex in components; reference these.",
    "color": {
      "action": {
        "default": "{global.color.rouge.500}",
        "hover": "{global.color.rouge.600}",
        "active": "{global.color.rouge.700}",
        "disabled": "{global.color.neutral.300}",
        "on": "{global.color.neutral.0}"
      },
      "reward": {
        "default": "{global.color.or.500}",
        "strong": "{global.color.or.600}",
        "on": "{global.color.neutral.900}"
      },
      "info": {
        "default": "{global.color.bleu.600}",
        "soft": "{global.color.bleu.100}",
        "on": "{global.color.neutral.0}"
      },
      "progress": {
        "default": "{global.color.vert.500}",
        "strong": "{global.color.vert.600}",
        "soft": "{global.color.vert.100}",
        "on": "{global.color.neutral.0}"
      },
      "danger": {
        "comment": "Red is the action color, so destructive states use the darkest red + an icon/label, never color alone.",
        "default": "{global.color.rouge.700}",
        "soft": "{global.color.rouge.50}",
        "on": "{global.color.neutral.0}"
      },
      "warning": {
        "default": "{global.color.or.600}",
        "soft": "{global.color.or.50}",
        "on": "{global.color.neutral.900}"
      },
      "text": {
        "primary": "{global.color.neutral.900}",
        "secondary": "{global.color.neutral.600}",
        "muted": "{global.color.neutral.500}",
        "on-ink": "{global.color.neutral.50}",
        "on-action": "{global.color.neutral.0}"
      },
      "border": {
        "subtle": "{global.color.neutral.200}",
        "strong": "{global.color.neutral.300}",
        "ink": "{global.color.neutral.900}"
      }
    }
  },

  "theme": {
    "comment": "Each surface sets its canvas + accent policy. Coach = ink + red everywhere; Admin = cream + red rare; EHPAD = cream + red near-absent, blue/green lead.",
    "coach": {
      "platform": "mobile (React Native)",
      "mood": "punchy · gamified · l'énergie",
      "color": {
        "canvas": "{global.color.neutral.900}",
        "surface": "{global.color.neutral.800}",
        "surface-raised": "{global.color.neutral.0}",
        "text-on-canvas": "{global.color.neutral.50}",
        "accent": "{global.color.rouge.500}",
        "accent-policy": "dominant — hero gradient, primary CTAs, badges, the engine"
      },
      "type-density": "expressive (large Anton stats, big CTAs)"
    },
    "admin": {
      "platform": "desktop web (React)",
      "mood": "structuré · piloté data · le calme du pro",
      "color": {
        "canvas": "{global.color.neutral.50}",
        "surface": "{global.color.neutral.0}",
        "surface-ink": "{global.color.neutral.900}",
        "text-on-canvas": "{global.color.neutral.900}",
        "accent": "{global.color.rouge.500}",
        "accent-policy": "rare — active nav item + alerts only; KPIs in gold, data tabular Anton",
        "data-lead": "{global.color.or.500}"
      },
      "type-density": "dense / tabular"
    },
    "ehpad": {
      "platform": "tablet-first responsive web (React)",
      "mood": "rassurant · lisible · le soin",
      "color": {
        "canvas": "{global.color.neutral.50}",
        "surface": "{global.color.neutral.0}",
        "text-on-canvas": "{global.color.neutral.900}",
        "accent": "{global.color.bleu.600}",
        "accent-secondary": "{global.color.vert.500}",
        "accent-policy": "red near-absent (CTAs only); blue=info, green=progress/santé lead the surface"
      },
      "type-density": "comfortable (larger body, generous spacing)"
    }
  },

  "typography": {
    "family": {
      "display": "Anton",
      "heading": "Oswald",
      "body": "Inter"
    },
    "weight": {
      "display": 400,
      "heading": 600,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "size": {
      "caption": 12, "body-sm": 14, "body": 16, "body-lg": 18,
      "subheading": 20, "h3": 24, "h2": 32, "h1": 40,
      "display": 48, "display-xl": 64
    },
    "line-height": { "tight": 1.0, "heading": 1.15, "snug": 1.25, "body": 1.5, "relaxed": 1.6 },
    "letter-spacing": { "tight": "-0.01em", "normal": "0", "label": "0.06em" },
    "style": {
      "display-hero": { "family": "display", "size": "display-xl", "weight": "display", "line-height": "tight", "transform": "uppercase", "use": "hero scores, medal counts (1 240 PTS)" },
      "display": { "family": "display", "size": "display", "weight": "display", "line-height": "tight", "transform": "uppercase" },
      "stat": { "family": "display", "size": "h2", "weight": "display", "line-height": "tight", "use": "KPI / card numbers" },
      "h1": { "family": "heading", "size": "h1", "weight": "heading", "line-height": "heading", "mobile-size": "h2" },
      "h2": { "family": "heading", "size": "h2", "weight": "heading", "line-height": "heading", "mobile-size": "h3" },
      "h3": { "family": "heading", "size": "h3", "weight": "heading", "line-height": "snug" },
      "title": { "family": "heading", "size": "subheading", "weight": "heading", "line-height": "snug" },
      "label": { "family": "heading", "size": "body-sm", "weight": "heading", "line-height": "snug", "transform": "uppercase", "letter-spacing": "label", "use": "nav, eyebrows, chips (PRIMAIRE · ACTION)" },
      "button": { "family": "heading", "size": "body", "weight": "heading", "transform": "uppercase", "letter-spacing": "label" },
      "body": { "family": "body", "size": "body", "weight": "regular", "line-height": "body" },
      "body-strong": { "family": "body", "size": "body", "weight": "semibold", "line-height": "body" },
      "body-sm": { "family": "body", "size": "body-sm", "weight": "regular", "line-height": "body" },
      "caption": { "family": "body", "size": "caption", "weight": "regular", "line-height": "snug" }
    }
  },

  "spacing": {
    "base": 4,
    "scale": { "0": 0, "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 32, "2xl": 48, "3xl": 64 }
  },

  "radius": {
    "none": 0, "sm": 8, "md": 12, "lg": 16, "xl": 24, "2xl": 32, "pill": 999
  },

  "size": {
    "touch-target-min": 44,
    "icon-sm": 16, "icon-md": 20, "icon-lg": 24, "avatar-sm": 32, "avatar-md": 48
  },

  "elevation": {
    "0": "none",
    "1": "0 1px 2px rgba(24,23,21,0.06), 0 1px 3px rgba(24,23,21,0.10)",
    "2": "0 4px 12px rgba(24,23,21,0.08)",
    "3": "0 12px 32px rgba(24,23,21,0.12)",
    "glow-action": "0 8px 24px rgba(225,50,43,0.35)"
  },

  "motion": {
    "duration": { "fast": "120ms", "base": "200ms", "slow": "320ms" },
    "easing": { "standard": "cubic-bezier(0.2, 0, 0, 1)", "decelerate": "cubic-bezier(0, 0, 0, 1)", "spring": "cubic-bezier(0.2, 0.8, 0.2, 1)" },
    "reduced-motion": "Honor prefers-reduced-motion: disable gradient shimmer, progress fill animation, and medal transitions; keep instant state changes."
  }
}
